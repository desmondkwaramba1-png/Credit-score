# CredAI — Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=CredAI Credit Scoring
APP_VERSION=1.0.0
# development | staging | production
APP_ENV=development
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/credit_scoring_db

# ─── Security ─────────────────────────────────────────────────────────────────
# Minimum 32 random characters — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# In development keep localhost ports; in production use your actual domain(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT=100/minute

# ─── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=app/ml/model.pkl
# Optional: URL to download the model from on first boot
# MODEL_URL=https://example.com/model.pkl

# ─── Redis (optional — needed for distributed rate limiting across workers) ────
# REDIS_URL=redis://redis:6379/0
